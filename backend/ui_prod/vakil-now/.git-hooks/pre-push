#!/bin/bash
set -euo pipefail

echo 'рҹҸ—пёҸ рҹ‘· Running build before push рҹ‘·вҖҚвҷӮпёҸрҹҸ—пёҸ'
echo 'Please be patient, this may take a while...'

if ! pnpm build; then
    echo 'вқҢвқҢвқҢ Build failed. Aborting Code Push. вқҢвқҢвқҢ'
    echo 'вҡЎпёҸвҡЎпёҸвҡЎпёҸ PLEASE CHECK and FIX the errors before pushing вҡЎпёҸвҡЎпёҸвҡЎпёҸ'
    exit 1
fi

