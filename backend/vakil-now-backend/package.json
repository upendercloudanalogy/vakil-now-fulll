{
  "name": "vakil-now-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "concurrently --kill-others -n \"NEST,STUDIO\" -c \"cyan.bold,yellow.bold\" \"pnpm run dev\" \"pnpm run studio\"",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "pull": "drizzle-kit pull",
    "studio": "drizzle-kit studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "setup:git-hooks": "git config core.hooksPath .git-hooks",
    "commit": "cz"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.540.0",
    "@aws-sdk/client-ses": "^3.922.0",
    "@aws-sdk/client-sesv2": "^3.922.0",
    "@aws-sdk/client-textract": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "3.540.0",
    "@bingsjs/pdf-parse": "^1.1.1",
    "@google-cloud/storage": "^7.19.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.12",
    "@sixaphone/nestjs-drizzle": "^1.0.1",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "exphbs": "^1.2.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.15.2",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "1.1.1",
    "pdf.js-extract": "^0.2.1",
    "pdfjs-dist": "^5.4.449",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pdfjs-dist": "^2.10.378",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "install": "^0.13.0",
    "jest": "^30.0.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs}": [
      "prettier --write .",
      "git add -A ."
    ]
  }
}