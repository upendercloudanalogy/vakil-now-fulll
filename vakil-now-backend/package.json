    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "exphbs": "^1.2.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.25",
    "mysql2": "^3.15.2",
    "otp-generator": "^4.0.1",
